{
  "expo": {
    "name": "마이약",
    "slug": "myyak",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "myyak",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.myyak.app",
      "infoPlist": {
        "NSCameraUsageDescription": "처방전 스캔을 위해 카메라 접근이 필요합니다.",
        "NSPhotoLibraryUsageDescription": "처방전 이미지를 선택하기 위해 갤러리 접근이 필요합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.myyak.app",
      "versionCode": 2,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "myyak",
              "host": "oauth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4A90D9",
          "sounds": []
        }
      ],
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "22d53cd19b422830d149f8d1fa209e3c",
          "kotlinVersion": "2.0.21"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "94c8d55d-4f20-4970-aad8-dc5e61604ef3"
      },
      "router": {}
    },
    "owner": "myyak_song"
  }
}
