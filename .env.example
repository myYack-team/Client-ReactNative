# MyYak Client 환경변수 설정 예시
# 이 파일을 .env로 복사하여 실제 값을 입력하세요
# cp .env.example .env

# ============================================
# API 설정
# ============================================
# 프로덕션 배포 시 설정 (없으면 기본값 사용)
# EXPO_PUBLIC_API_BASE_URL=https://api.myyak.com/api

# ============================================
# 카카오 로그인
# ============================================
# https://developers.kakao.com 에서 발급
EXPO_PUBLIC_KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY
